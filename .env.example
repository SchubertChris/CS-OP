# Neon Postgres connection string
database_url=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# bcrypt hash of admin password (salt rounds 12)
admin_password_hash=$2a$12$...

# Random 32+ char secret for JWT signing
jwt_secret=your_random_secret_here

# One-time setup token for TOTP enrollment — delete after setup!
setup_token=your_random_token_here

# TOTP secret — set after running /api/auth/totp-setup
totp_secret=BASE32SECRETHERE
